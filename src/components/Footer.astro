---
const year = new Date().getFullYear();
---
<footer style="
  background: oklch(0.08 0.02 32);
  border-top: 1px solid oklch(0.72 0.14 60 / 0.12);
">
  <div class="max-w-5xl mx-auto px-6 sm:px-8 py-12">

    <!-- Top row: logo + tagline + social -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 mb-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-2">
          <svg width="24" height="17" viewBox="0 0 28 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polyline points="0,10 3,5 6,10 9,15 12,10 15,3 18,10 21,17 24,10 28,10"
                      stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          <span class="font-display" style="font-size: 1.1rem; font-weight: 500; font-style: italic; color: oklch(0.88 0.03 70);">
            Croisonido
          </span>
        </div>
        <p class="font-body text-xs" style="color: oklch(0.45 0.02 50); font-weight: 300; letter-spacing: 0.05em;">
          Where Every Bite Has a Beat
        </p>
      </div>

      <!-- Quick links -->
      <div class="flex items-center gap-6">
        <a href="#story" class="text-xs font-body tracking-[0.12em] uppercase transition-colors duration-200"
           style="color: oklch(0.50 0.025 55);"
           onmouseover="this.style.color='oklch(0.72 0.14 60)'"
           onmouseout="this.style.color='oklch(0.50 0.025 55)'">Story</a>
        <a href="#experience" class="text-xs font-body tracking-[0.12em] uppercase transition-colors duration-200"
           style="color: oklch(0.50 0.025 55);"
           onmouseover="this.style.color='oklch(0.72 0.14 60)'"
           onmouseout="this.style.color='oklch(0.50 0.025 55)'">Menu</a>
        <a href="https://instagram.com/croisonido" class="text-xs font-body tracking-[0.12em] uppercase transition-colors duration-200"
           style="color: oklch(0.50 0.025 55);"
           onmouseover="this.style.color='oklch(0.72 0.14 60)'"
           onmouseout="this.style.color='oklch(0.50 0.025 55)'">Instagram</a>
        <a href="mailto:hola@croisonido.co" class="text-xs font-body tracking-[0.12em] uppercase transition-colors duration-200"
           style="color: oklch(0.50 0.025 55);"
           onmouseover="this.style.color='oklch(0.72 0.14 60)'"
           onmouseout="this.style.color='oklch(0.50 0.025 55)'">Contact</a>
      </div>
    </div>

    <!-- Divider waveform -->
    <div style="margin: 0 0 2rem; opacity: 0.08;">
      <svg viewBox="0 0 1200 20" preserveAspectRatio="none" style="width:100%; height:16px; display:block;">
        <path d="M0 10 Q75 2 150 10 Q225 18 300 10 Q375 2 450 10 Q525 18 600 10 Q675 2 750 10 Q825 18 900 10 Q975 2 1050 10 Q1125 18 1200 10"
              stroke="oklch(0.72 0.14 60)" stroke-width="1" fill="none"/>
      </svg>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="font-body text-xs" style="color: oklch(0.38 0.015 45); font-weight: 300;">
        &copy; {year} Croisonido · El Poblado, Medellín, Colombia
      </p>
      <p class="font-body text-xs" style="color: oklch(0.38 0.015 45); font-weight: 300;">
        Artisan pastry · Progressive music · Medellín's golden hour
      </p>
    </div>
  </div>
</footer>
