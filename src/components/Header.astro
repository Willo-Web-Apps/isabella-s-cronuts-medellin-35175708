---
---
<header class="sticky top-0 z-50" style="
  background: oklch(0.10 0.025 35 / 0.85);
  backdrop-filter: blur(16px) saturate(1.2);
  border-bottom: 1px solid oklch(0.72 0.14 60 / 0.12);
">
  <nav class="max-w-5xl mx-auto px-6 sm:px-8 h-16 flex items-center justify-between">

    <!-- Logo mark + wordmark -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- Waveform logomark -->
      <svg width="28" height="20" viewBox="0 0 28 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;">
        <polyline points="0,10 3,5 6,10 9,15 12,10 15,3 18,10 21,17 24,10 28,10"
                  stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <span class="font-display tracking-wide" style="
        font-size: 1.2rem;
        font-weight: 500;
        font-style: italic;
        color: oklch(0.94 0.02 65);
        transition: color 0.2s;
      ">
        Croisonido
      </span>
    </a>

    <!-- Nav links -->
    <div class="flex items-center gap-6 sm:gap-8">
      <a href="#story" class="hidden sm:block text-xs font-body font-400 tracking-[0.15em] uppercase transition-colors duration-200"
         style="color: oklch(0.60 0.025 60);"
         onmouseover="this.style.color='oklch(0.72 0.14 60)'"
         onmouseout="this.style.color='oklch(0.60 0.025 60)'">
        Story
      </a>
      <a href="#experience" class="hidden sm:block text-xs font-body font-400 tracking-[0.15em] uppercase transition-colors duration-200"
         style="color: oklch(0.60 0.025 60);"
         onmouseover="this.style.color='oklch(0.72 0.14 60)'"
         onmouseout="this.style.color='oklch(0.60 0.025 60)'">
        Menu
      </a>
      <a href="#cta" class="text-xs font-body font-500 tracking-[0.15em] uppercase px-5 py-2.5 transition-all duration-200"
         style="
           background: oklch(0.72 0.14 60 / 0.12);
           color: oklch(0.72 0.14 60);
           border: 1px solid oklch(0.72 0.14 60 / 0.3);
           border-radius: 2px;
         "
         onmouseover="this.style.background='oklch(0.72 0.14 60 / 0.22)'"
         onmouseout="this.style.background='oklch(0.72 0.14 60 / 0.12)'">
        Reserve
      </a>
    </div>
  </nav>
</header>
