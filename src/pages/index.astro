---
import Base from '../layouts/Base.astro';
---
<Base
  title="Croisonido — Artisan Cronuts & Progressive Beats, Medellín"
  description="Hand-crafted croissant-donuts and curated DJ sets by Isabella. Medellín's first artisan cronut lounge — a sensory experience born in the eternal spring city."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Immersive dark atmospheric opening
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden noise-overlay" style="background: oklch(0.10 0.025 35);">

    <!-- Layered gradient: ambient golden-hour glow from upper-right + lower-left warmth -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 80% 60% at 78% 18%, oklch(0.72 0.14 60 / 0.22) 0%, transparent 65%),
        radial-gradient(ellipse 55% 45% at 15% 85%, oklch(0.60 0.12 42 / 0.18) 0%, transparent 60%),
        radial-gradient(ellipse 40% 35% at 50% 50%, oklch(0.20 0.04 40 / 0.50) 0%, transparent 70%),
        linear-gradient(168deg, oklch(0.13 0.03 38) 0%, oklch(0.08 0.02 32) 100%);
      mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
    "></div>

    <!-- Animated secondary glow — breathes slowly -->
    <div class="absolute inset-0 animate-glow-pulse" style="
      background: radial-gradient(ellipse 60% 50% at 70% 25%, oklch(0.72 0.14 60 / 0.12) 0%, transparent 55%);
      pointer-events: none;
    "></div>

    <!-- Subtle dot grid texture -->
    <div class="absolute inset-0" style="
      background-image: radial-gradient(circle at 1px 1px, oklch(0.72 0.14 60 / 0.06) 1px, transparent 0);
      background-size: 28px 28px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
      pointer-events: none;
    "></div>

    <!-- Waveform decorative element — subtle DJ groove motif -->
    <div class="absolute bottom-24 left-0 right-0 opacity-10 pointer-events-none">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:60px;">
        <path d="M0 30 Q60 10 120 30 Q180 50 240 30 Q300 10 360 30 Q420 50 480 30 Q540 10 600 30 Q660 50 720 30 Q780 10 840 30 Q900 50 960 30 Q1020 10 1080 30 Q1140 50 1200 30 Q1260 10 1320 30 Q1380 50 1440 30"
              stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M0 30 Q40 18 80 30 Q120 42 160 30 Q200 18 240 30 Q280 42 320 30 Q360 18 400 30 Q440 42 480 30 Q520 18 560 30 Q600 42 640 30 Q680 18 720 30 Q760 42 800 30 Q840 18 880 30 Q920 42 960 30 Q1000 18 1040 30 Q1080 42 1120 30 Q1160 18 1200 30 Q1240 42 1280 30 Q1320 18 1360 30 Q1400 42 1440 30"
              stroke="oklch(0.72 0.14 60 / 0.5)" stroke-width="0.75" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-8 text-center" style="z-index: 3;">

      <!-- Label / eyebrow -->
      <p class="animate-fade-in text-xs tracking-[0.35em] uppercase font-body font-500 mb-8" style="color: oklch(0.72 0.14 60);">
        Medellín · Colombia
      </p>

      <!-- Main headline — dramatic Cormorant Garamond italic -->
      <h1 class="animate-slide-up font-display leading-[0.92] tracking-tight" style="
        font-size: clamp(3.5rem, 10vw, 8rem);
        font-weight: 300;
        font-style: italic;
        color: oklch(0.94 0.02 65);
      ">
        Artisan Cronuts.<br/>
        <span style="
          background: linear-gradient(135deg, oklch(0.72 0.14 60) 0%, oklch(0.85 0.12 68) 50%, oklch(0.72 0.14 60) 100%);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        ">Progressive Beats.</span><br/>
        Medellín's Best&nbsp;Hour.
      </h1>

      <!-- Sub headline -->
      <p class="animate-slide-up delay-200 font-body mt-8 max-w-xl mx-auto leading-relaxed" style="
        font-size: 1.05rem;
        font-weight: 300;
        color: oklch(0.75 0.03 65);
        letter-spacing: 0.02em;
      ">
        Hand-crafted croissant-donuts and curated DJ sets by Isabella —<br class="hidden sm:block"/>
        a sensory experience born in Medellín.
      </p>

      <!-- CTAs -->
      <div class="animate-slide-up delay-300 mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#experience" class="group inline-flex items-center gap-2 px-8 py-3.5 font-body font-500 text-sm tracking-wider uppercase transition-all duration-300"
           style="background: oklch(0.72 0.14 60); color: oklch(0.10 0.025 35); border-radius: 2px; letter-spacing: 0.1em;">
          Reserve Your Table
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#story" class="inline-flex items-center gap-2 px-8 py-3.5 font-body font-500 text-sm tracking-wider uppercase transition-all duration-300"
           style="border: 1px solid oklch(0.72 0.14 60 / 0.35); color: oklch(0.88 0.03 70); border-radius: 2px; letter-spacing: 0.1em;">
          Our Story
        </a>
      </div>

      <!-- Micro-proof -->
      <p class="animate-fade-in delay-400 mt-8 text-xs font-body" style="color: oklch(0.50 0.025 50); letter-spacing: 0.05em;">
        Open Wednesday – Sunday · El Poblado, Medellín
      </p>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-fade-in delay-600">
      <span class="text-xs font-body tracking-[0.2em] uppercase" style="color: oklch(0.72 0.14 60 / 0.5);">Descend</span>
      <div style="width: 1px; height: 40px; background: linear-gradient(to bottom, oklch(0.72 0.14 60 / 0.5), transparent);"></div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       ORIGIN STORY — Immersive narrative
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="story" class="relative overflow-hidden" style="background: oklch(0.12 0.025 36);">

    <!-- Ambient warm glow from right edge -->
    <div class="absolute inset-0 pointer-events-none" style="
      background: radial-gradient(ellipse 50% 70% at 95% 40%, oklch(0.72 0.14 60 / 0.08) 0%, transparent 60%);
    "></div>

    <div class="max-w-5xl mx-auto px-6 sm:px-8 py-24 md:py-32">

      <!-- Section label -->
      <div class="mb-4">
        <span class="accent-bar"></span>
        <p class="text-xs tracking-[0.3em] uppercase font-body font-500" style="color: oklch(0.72 0.14 60);">Our Origin</p>
      </div>

      <!-- Asymmetric layout: big heading left, text right -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-start">

        <!-- Left: dramatic heading -->
        <div class="animate-slide-up">
          <h2 class="font-display leading-[0.9]" style="
            font-size: clamp(2.8rem, 6vw, 5rem);
            font-weight: 300;
            font-style: italic;
            color: oklch(0.94 0.02 65);
          ">
            Born from<br/>
            <em style="color: oklch(0.72 0.14 60); font-style: italic;">eternal&nbsp;spring</em><br/>
            and golden dough.
          </h2>

          <!-- Large pull quote number -->
          <div class="mt-12 md:mt-16 border-t pt-8" style="border-color: oklch(0.72 0.14 60 / 0.2);">
            <p class="font-display" style="font-size: 5rem; font-weight: 700; color: oklch(0.72 0.14 60 / 0.18); line-height: 1;">
              27
            </p>
            <p class="font-body text-sm mt-1" style="color: oklch(0.60 0.03 62); letter-spacing: 0.05em;">
              Layers of laminated dough in every cronut
            </p>
          </div>
        </div>

        <!-- Right: narrative paragraphs -->
        <div class="animate-slide-up delay-200 space-y-6 font-body" style="color: oklch(0.72 0.03 62); font-weight: 300; line-height: 1.85; font-size: 1.0625rem;">
          <p>
            Croisonido was born from a simple obsession: what happens when a pastry chef who trained in Lyon and a DJ who soundtracked Medellín's underground scene find themselves sharing a kitchen table in El Poblado?
          </p>
          <p>
            The answer was 27 layers of butter-laminated dough, fried to a honeyed crisp, glazed with rotating seasonal flavors — and a sound system tuned to progressive house frequencies that fill the room like perfume.
          </p>
          <p>
            We didn't want another café. We wanted a destination. A place where your afternoon becomes a small, beautiful event.
          </p>

          <!-- Pull quote -->
          <blockquote class="relative pl-6 mt-8" style="border-left: 2px solid oklch(0.72 0.14 60 / 0.5);">
            <p class="font-display font-300 leading-snug" style="font-size: 1.4rem; font-style: italic; color: oklch(0.88 0.03 70);">
              "Every visit should feel like arriving somewhere special."
            </p>
            <cite class="mt-3 block text-xs font-body tracking-[0.2em] uppercase not-italic" style="color: oklch(0.72 0.14 60);">
              — The Croisonido Kitchen
            </cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       WAVEFORM DIVIDER
       ═══════════════════════════════════════════════════════════════════ -->
  <div style="background: oklch(0.12 0.025 36); line-height: 0; overflow: hidden;">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" style="width:100%; height:40px; display:block;">
      <path d="M0 20 Q90 5 180 20 Q270 35 360 20 Q450 5 540 20 Q630 35 720 20 Q810 5 900 20 Q990 35 1080 20 Q1170 5 1260 20 Q1350 35 1440 20 L1440 40 L0 40 Z"
            fill="oklch(0.155 0.025 38)"/>
    </svg>
  </div>


  <!-- ═══════════════════════════════════════════════════════════════════
       THE EXPERIENCE — Sensory sections (Values / Principles)
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="experience" class="relative overflow-hidden" style="background: oklch(0.155 0.025 38);">

    <div class="max-w-5xl mx-auto px-6 sm:px-8 py-24 md:py-32">

      <!-- Section heading -->
      <div class="text-center mb-20">
        <span class="accent-bar"></span>
        <p class="text-xs tracking-[0.3em] uppercase font-body mb-4" style="color: oklch(0.72 0.14 60);">What We Offer</p>
        <h2 class="font-display leading-tight" style="
          font-size: clamp(2.2rem, 5vw, 4rem);
          font-weight: 300;
          font-style: italic;
          color: oklch(0.94 0.02 65);
        ">
          Three senses.<br/>One afternoon.
        </h2>
      </div>

      <!-- Three pillars — asymmetric grid -->
      <div class="grid md:grid-cols-3 gap-px" style="background: oklch(0.72 0.14 60 / 0.12);">

        <!-- Pillar 1: Pastry -->
        <div class="p-8 md:p-10 animate-slide-up" style="background: oklch(0.155 0.025 38);">
          <!-- Icon: layered dough / croissant -->
          <div class="mb-6 w-10 h-10 flex items-center justify-center" style="border: 1px solid oklch(0.72 0.14 60 / 0.4); border-radius: 2px;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6 2 3 7 3 12s3 10 9 10 9-5 9-10S18 2 12 2z"/>
              <path d="M8 12h8M8 8.5h8M8 15.5h8"/>
            </svg>
          </div>
          <h3 class="font-display mb-3" style="font-size: 1.7rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
            The Cronut
          </h3>
          <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300;">
            27 layers of butter-laminated dough, fried fresh each morning, glazed with rotating seasonal flavors — yuzu curd, passion-fruit caramel, Colombian panela dark chocolate. Never frozen. Never rushed.
          </p>
          <p class="mt-5 text-xs font-body tracking-[0.2em] uppercase" style="color: oklch(0.72 0.14 60);">
            Artisan Pastry
          </p>
        </div>

        <!-- Pillar 2: Music -->
        <div class="p-8 md:p-10 animate-slide-up delay-100" style="background: oklch(0.155 0.025 38);">
          <!-- Icon: waveform / headphones -->
          <div class="mb-6 w-10 h-10 flex items-center justify-center" style="border: 1px solid oklch(0.72 0.14 60 / 0.4); border-radius: 2px;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 18v-6a9 9 0 0118 0v6"/>
              <path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/>
            </svg>
          </div>
          <h3 class="font-display mb-3" style="font-size: 1.7rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
            Isabella's Sets
          </h3>
          <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300;">
            Resident DJ Isabella curates live progressive house sets every Wednesday through Sunday — from melodic afternoon grooves that let you think, to deep evening frequencies that keep you seated long past your last bite.
          </p>
          <p class="mt-5 text-xs font-body tracking-[0.2em] uppercase" style="color: oklch(0.72 0.14 60);">
            Progressive Electronic
          </p>
        </div>

        <!-- Pillar 3: Specialty Coffee -->
        <div class="p-8 md:p-10 animate-slide-up delay-200" style="background: oklch(0.155 0.025 38);">
          <!-- Icon: coffee -->
          <div class="mb-6 w-10 h-10 flex items-center justify-center" style="border: 1px solid oklch(0.72 0.14 60 / 0.4); border-radius: 2px;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 8h1a4 4 0 010 8h-1"/>
              <path d="M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
          </div>
          <h3 class="font-display mb-3" style="font-size: 1.7rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
            Specialty Coffee
          </h3>
          <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300;">
            Single-origin Colombian beans sourced from Huila and Nariño, brewed filter, espresso, or cold-brew. Each cup is chosen to pair with our pastry menu the way a sommelier pairs wine — with intention.
          </p>
          <p class="mt-5 text-xs font-body tracking-[0.2em] uppercase" style="color: oklch(0.72 0.14 60);">
            Single-Origin Colombia
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       TIMELINE / PROCESS — The Croisonido Ritual
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background: oklch(0.12 0.025 36);">

    <!-- Ambient left glow -->
    <div class="absolute inset-0 pointer-events-none" style="
      background: radial-gradient(ellipse 40% 60% at 5% 60%, oklch(0.72 0.14 60 / 0.07) 0%, transparent 55%);
    "></div>

    <div class="max-w-5xl mx-auto px-6 sm:px-8 py-24 md:py-32">

      <!-- Section heading -->
      <div class="mb-16">
        <span class="accent-bar"></span>
        <p class="text-xs tracking-[0.3em] uppercase font-body mb-4" style="color: oklch(0.72 0.14 60);">The Ritual</p>
        <h2 class="font-display leading-tight" style="
          font-size: clamp(2.2rem, 5vw, 4rem);
          font-weight: 300;
          font-style: italic;
          color: oklch(0.94 0.02 65);
          max-width: 30ch;
        ">
          Every visit feels like a small event.
        </h2>
      </div>

      <!-- Timeline steps — vertical line motif -->
      <div class="relative">
        <!-- Vertical connector line -->
        <div class="absolute left-[1.15rem] top-0 bottom-0 w-px hidden md:block" style="background: linear-gradient(to bottom, oklch(0.72 0.14 60 / 0.3), transparent);"></div>

        <div class="space-y-12 md:space-y-10">

          <!-- Step 1 -->
          <div class="flex gap-6 md:gap-10 items-start animate-slide-up">
            <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-xs font-body font-600 relative z-10"
                 style="background: oklch(0.72 0.14 60); color: oklch(0.10 0.025 35); font-size: 0.75rem; letter-spacing: 0.05em;">
              01
            </div>
            <div class="pt-1">
              <h3 class="font-display mb-2" style="font-size: 1.4rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
                Arrive & Settle
              </h3>
              <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300; max-width: 50ch;">
                Find your table in El Poblado's warmest corner. The room is lit by amber pendants, the sound is already moving. You're not early. You're right on time.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-6 md:gap-10 items-start animate-slide-up delay-100">
            <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-xs font-body font-600 relative z-10"
                 style="background: oklch(0.20 0.025 40); color: oklch(0.72 0.14 60); border: 1px solid oklch(0.72 0.14 60 / 0.4); font-size: 0.75rem; letter-spacing: 0.05em;">
              02
            </div>
            <div class="pt-1">
              <h3 class="font-display mb-2" style="font-size: 1.4rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
                Choose Your Cronut
              </h3>
              <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300; max-width: 50ch;">
                Today's seasonal glaze. A specialty coffee or cold brew. The menu is short on purpose — every item has earned its place.
              </p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-6 md:gap-10 items-start animate-slide-up delay-200">
            <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-xs font-body font-600 relative z-10"
                 style="background: oklch(0.20 0.025 40); color: oklch(0.72 0.14 60); border: 1px solid oklch(0.72 0.14 60 / 0.4); font-size: 0.75rem; letter-spacing: 0.05em;">
              03
            </div>
            <div class="pt-1">
              <h3 class="font-display mb-2" style="font-size: 1.4rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
                Let Isabella Set the Pace
              </h3>
              <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300; max-width: 50ch;">
                From melodic afternoon progressions to deeper evening frequencies, the music shapes your hour. Put the phone down. The feed can wait.
              </p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="flex gap-6 md:gap-10 items-start animate-slide-up delay-300">
            <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-xs font-body font-600 relative z-10"
                 style="background: oklch(0.20 0.025 40); color: oklch(0.72 0.14 60); border: 1px solid oklch(0.72 0.14 60 / 0.4); font-size: 0.75rem; letter-spacing: 0.05em;">
              04
            </div>
            <div class="pt-1">
              <h3 class="font-display mb-2" style="font-size: 1.4rem; font-weight: 400; font-style: italic; color: oklch(0.94 0.02 65);">
                Leave Different
              </h3>
              <p class="font-body text-sm leading-relaxed" style="color: oklch(0.65 0.025 60); font-weight: 300; max-width: 50ch;">
                You came for a pastry. You stayed for the feeling. That's Croisonido. Come back when Medellín's golden hour calls you again.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       FLAVORS — Rotating Seasonal Menu Highlight
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden noise-overlay" style="background: oklch(0.155 0.025 38);">

    <div class="max-w-5xl mx-auto px-6 sm:px-8 py-24 md:py-32">
      <div class="text-center mb-16">
        <span class="accent-bar" style="margin: 0 auto 1.25rem; display:block;"></span>
        <p class="text-xs tracking-[0.3em] uppercase font-body mb-4" style="color: oklch(0.72 0.14 60);">This Season</p>
        <h2 class="font-display leading-tight" style="
          font-size: clamp(2.2rem, 5vw, 3.8rem);
          font-weight: 300;
          font-style: italic;
          color: oklch(0.94 0.02 65);
        ">
          The Current Menu
        </h2>
        <p class="font-body mt-4 max-w-md mx-auto" style="font-size: 0.9rem; color: oklch(0.60 0.025 58); font-weight: 300; line-height: 1.8;">
          Flavors rotate weekly. These are today's. Tomorrow is a surprise.
        </p>
      </div>

      <!-- Flavor cards — staggered horizontal scroll on mobile -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px" style="background: oklch(0.72 0.14 60 / 0.1);">

        <div class="p-7 animate-slide-up" style="background: oklch(0.155 0.025 38);">
          <p class="font-display mb-1" style="font-size: 1.1rem; font-style: italic; color: oklch(0.94 0.02 65);">Yuzu Curd</p>
          <p class="font-display mb-3" style="font-size: 0.8rem; font-weight: 300; color: oklch(0.72 0.14 60); letter-spacing: 0.05em;">& toasted sesame</p>
          <p class="font-body text-xs leading-relaxed" style="color: oklch(0.55 0.025 55); font-weight: 300;">Bright citrus cuts the richness of laminated dough. A pairing that shouldn't work — and absolutely does.</p>
        </div>

        <div class="p-7 animate-slide-up delay-100" style="background: oklch(0.155 0.025 38);">
          <p class="font-display mb-1" style="font-size: 1.1rem; font-style: italic; color: oklch(0.94 0.02 65);">Panela Chocolate</p>
          <p class="font-display mb-3" style="font-size: 0.8rem; font-weight: 300; color: oklch(0.72 0.14 60); letter-spacing: 0.05em;">& fleur de sel</p>
          <p class="font-body text-xs leading-relaxed" style="color: oklch(0.55 0.025 55); font-weight: 300;">Colombian raw sugar caramelized into a dark glaze. Earthy, complex, unmistakably local.</p>
        </div>

