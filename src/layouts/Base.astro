---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Croisonido — Artisan Cronuts & Progressive Beats, Medellín",
  description = "Hand-crafted croissant-donuts and curated DJ sets by Isabella. Medellín's first artisan cronut lounge — a sensory experience born in the eternal spring city."
} = Astro.props;
---
<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="cronut Medellín, artisan pastry Colombia, DJ café Medellín, Croisonido, progressive house café, Isabella DJ, croissant donut El Poblado" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#1A0F0A" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FoodEstablishment",
      "name": "Croisonido",
      "description": "Medellín's first artisan cronut lounge — hand-crafted croissant-donuts and curated progressive DJ sets by Isabella.",
      "url": "https://croisonido.onrender.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "El Poblado",
        "addressRegion": "Medellín",
        "addressCountry": "CO"
      },
      "servesCuisine": ["Pastry", "Coffee"],
      "openingHours": ["We-Su 14:00-21:00"]
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.10 0.025 35); color: oklch(0.88 0.03 70);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
